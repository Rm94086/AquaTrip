<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Avalie sua experiência — Aquatrip</title>
    <link rel="stylesheet" href="avaliação.css" />
  </head>
  <body>

    <main>

      <section aria-labelledby="lbl-stars">
        <h2 id="lbl-stars">Avaliação geral</h2>
        <nav class="stars-row" role="group" aria-label="Selecione sua nota">
          <button type="button" data-val="1" aria-label="1 estrela">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path class="star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
          </button>
          <button type="button" data-val="2" aria-label="2 estrelas">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path class="star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
          </button>
          <button type="button" data-val="3" aria-label="3 estrelas">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path class="star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
          </button>
          <button type="button" data-val="4" aria-label="4 estrelas">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path class="star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
          </button>
          <button type="button" data-val="5" aria-label="5 estrelas">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path class="star-empty" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
          </button>
        </nav>
        <output id="star-label">Toque nas estrelas para avaliar</output>
        <strong class="err" id="star-error">Por favor, selecione uma avaliação.</strong>
      </section>

      <hr />

      <section aria-labelledby="lbl-title">
        <h2 id="lbl-title">Título da avaliação</h2>
        <label for="review-title">Resuma sua experiência em uma frase</label>
        <input type="text" id="review-title" placeholder="Ex: Uma viagem que não vou esquecer!" maxlength="80" />
        <small><span id="title-count">0</span>/80</small>
        <strong class="err" id="title-error">Por favor, adicione um título.</strong>
      </section>

      <hr />

      <section aria-labelledby="lbl-body">
        <h2 id="lbl-body">Sua avaliação</h2>
        <label for="review-text">Conte tudo sobre sua experiência</label>
        <textarea id="review-text" placeholder="O que você mais gostou? O atendimento, os passeios, as paisagens? Fique à vontade para compartilhar!" maxlength="800"></textarea>
        <small><span id="text-count">0</span>/800</small>
        <strong class="err" id="text-error">Por favor, escreva sua avaliação.</strong>
      </section>

      <hr />

      <section aria-labelledby="lbl-photos">
        <h2 id="lbl-photos">Fotos <em class="optional">— opcional</em></h2>
        <label for="file-input">Adicione até 5 fotos da sua experiência</label>
        <article
          class="upload-zone"
          id="upload-area"
          role="button"
          tabindex="0"
          aria-label="Clique para adicionar fotos"
        >
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5" />
            <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" />
            <path d="M3 15l5-5 4 4 3-3 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <p>
            <b>Clique para enviar fotos</b> ou arraste aqui
            <span>JPG, PNG ou WEBP · Máx. 5 fotos · 10 MB cada</span>
          </p>
        </article>
        <input type="file" id="file-input" multiple accept="image/*" />
        <ul class="previews" id="previews"></ul>
      </section>

           <button type="submit" id="submit-btn">Enviar avaliação</button>
      <aside class="success" id="success-banner" aria-live="polite" hidden>
        ✓ Obrigado! Sua avaliação foi enviada com sucesso.
      </aside>

    </main>

    <script src="avaliação.js"></script>
  </body>
</html>
